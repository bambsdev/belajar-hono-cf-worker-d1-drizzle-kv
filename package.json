{
  "name": "deploy-to-cf-worker",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "drizzle-kit migrate --config drizzle.config.local.ts",
    "db:migrate:all": "npm run db:migrate && npm run db:migrate:local",
    "db:push": "drizzle-kit push",
    "db:push:local": "drizzle-kit push --config drizzle.config.local.ts",
    "db:studio": "drizzle-kit studio",
    "db:studio:local": "drizzle-kit studio --config drizzle.config.local.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260228.1",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "wrangler": "^4.4.0"
  }
}
